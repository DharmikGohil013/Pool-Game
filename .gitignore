# Standard Unity .gitignore

# Unity generated folders
[L/l]ibrary/
[T/t]emp/
[O/o]bj/
[B/b]uild/
[B/b]uilds/
[L/l]ogs/
[U/u]serSettings/
[M/m]emoryCaptures/
[R/r]ecordings/

# Asset store tools plugin
[A/a]ssets/AssetStoreTools*

# Autogenerated Visual Studio / Rider / MonoDevelop project files
ExportedObj/
.consulo/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.opendb
*.VC.db

# Unity generated file changes properties
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Visual Studio / Visual Studio Code / JetBrains Rider
.vs/
.idea/
.vscode/
.vsconfig

# Crash reports & memory dumps
*.lldb
*.dmp
sysinfo.txt

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
